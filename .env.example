# ─────────────────────────────────────────────────────────────
# LocalScore — environment template. Copy to `.env` and edit.
# ─────────────────────────────────────────────────────────────

# --- App ---
ENVIRONMENT=development
DEBUG=true
PROJECT_NAME=LocalScore
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# --- Database (local MySQL/TiDB-compatible via docker-compose) ---
# Async driver for the app:
DATABASE_URL=mysql+aiomysql://localscore:localscore@db:3306/localscore
# Sync driver for Alembic migrations:
SYNC_DATABASE_URL=mysql+pymysql://localscore:localscore@db:3306/localscore
# Set true for managed MySQL that requires TLS (e.g. TiDB Cloud Serverless).
DB_SSL=false

# --- Redis (Socket.IO pub/sub + cache) ---
REDIS_URL=redis://redis:6379/0

# --- Rate limiting (per IP, per endpoint, per minute) on auth + write routes ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

# --- Object storage (MinIO locally, S3 in prod) ---
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=localscore-media
S3_REGION=us-east-1

# --- AI service (Phase 4) ---
AI_SERVICE_URL=http://ai-service:8100
OPENAI_API_KEY=

# --- MySQL container bootstrap (used by docker-compose db service) ---
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=localscore
MYSQL_USER=localscore
MYSQL_PASSWORD=localscore
