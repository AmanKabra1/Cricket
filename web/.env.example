# Web app environment. Copy to `.env` for non-default values.
# In dev, leaving these unset uses Vite's proxy to http://localhost:8000.

# Absolute API base (e.g. production): https://api.localscore.app/api/v1
VITE_API_BASE_URL=/api/v1

# Socket.IO origin. Empty = same origin (works with the dev proxy).
VITE_SOCKET_URL=
