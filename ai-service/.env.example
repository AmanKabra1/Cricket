# AI service environment. Copy to `.env`.
DEBUG=true

# Optional — enables LLM commentary/summaries. Without any key, templates are used.
# Preferred: Google Gemini (free tier, no card). Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Alternative: OpenAI (needs the langchain-openai extra installed).
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Where trained model artifacts live. Absent → heuristic predictors are used.
MODEL_DIR=models
